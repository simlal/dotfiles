      "npm info *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "grep *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "jq *": "allow",
      "column *": "allow",
      "rev *": "allow",
      "nl *": "allow",
      "tac *": "allow"
    }
