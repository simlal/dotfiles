{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "read": "allow",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "task": "ask",
    "question": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git reset *": "ask",
      "git clean *": "ask",
      "git checkout *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "gh *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "tree *": "allow",
      "pwd": "allow",
      "date *": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "which *": "allow",
      "type *": "allow",
      "echo *": "allow",
      "docker ps *": "allow",
      "docker images *": "allow",
      "docker inspect *": "allow",
      "docker logs *": "allow",
      "docker version": "allow",
      "docker info": "allow",
      "npm ls *": "allow",
      "npm list *": "allow",
      "npm view *": "allow",
      "npm info *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "grep *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "jq *": "allow",
      "column *": "allow",
      "rev *": "allow",
      "nl *": "allow",
      "tac *": "allow"
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://localhost:8081/v1"
      },
      "models": {
        "qwen2.5-coder-14b": {
          "name": "Qwen 2.5 Coder 14B (local)",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    }
  }
}
